include ../data/typography-module-data

section(class='typography-module')
	div(class='typography-module__container')
		h2(class='typography-module__title')= typographyModuleData.title
		p(class='typography-module__lead')= typographyModuleData.lead

		article(class='typography-module__specimen')
			p(class='typography-module__family-name')= typographyModuleData.family
			p(class='typography-module__meta') Stack: #{typographyModuleData.family}, #{typographyModuleData.fallback}
			p(class='typography-module__alphabet')
				| ABCDEFGHIJKLMNOPQRSTUVWXYZ
				br
				| abcdefghijklmnopqrstuvwxyz
				br
				| 0123456789 !@#$%&*()
			p(class='typography-module__pangram') El veloz murcielago hindu comia feliz cardillo y kiwi.

		div(class='typography-module__weights')
			each weight in typographyModuleData.weights
				p(class='typography-module__weight' style=`font-weight: ${weight.value}`)
					span(class='typography-module__weight-label') #{weight.name} (#{weight.value})
					span(class='typography-module__weight-sample') The quick brown fox jumps over the lazy dog.

		hr(class='typography-module__divider')

		div(class='typography-module__scale')
			h3(class='typography-module__scale-title') Escala tipografica
			h1 h1 — Heading 1
			h2 h2 — Heading 2
			h3 h3 — Heading 3
			h4 h4 — Heading 4
			h5 h5 — Heading 5
			h6 h6 — Heading 6
			ul
				li Lorem ipsum dolor sit amet consectetur adipisicing elit. Quisquam, quos.
				li Lorem ipsum dolor sit amet consectetur adipisicing elit. Quisquam, quos.
			p
				| Lorem ipsum dolor sit amet consectetur, adipisicing elit. Quasi,
				| dolorem autem maiores quis dolor, reprehenderit delectus quia dolore,
				| incidunt obcaecati sequi labore hic? Soluta doloremque vitae explicabo
				| assumenda fugit tenetur.
